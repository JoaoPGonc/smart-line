# Firebase project configuration.
# Copy this file to .env and fill in the values from your Firebase project
# settings (console.firebase.google.com > Project settings > General).
# Never commit the real .env file — it is already covered by .gitignore.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Only needed if you use a named (non-default) Firestore database.
VITE_FIREBASE_FIRESTORE_DATABASE_ID=
